{
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PLUGIN_ROOT\"/hooks/scripts/enforce-source-only.sh"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "\"$CLAUDE_PLUGIN_ROOT\"/hooks/scripts/chezmoi-diff-reminder.sh"
					}
				]
			}
		]
	}
}
