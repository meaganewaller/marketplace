{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "./hooks/scripts/post-tool-use.sh"
					}
				]
			}
		],
		"PreCompact": [
			{
				"matcher": "auto",
				"hooks": [
					{
						"type": "command",
						"command": "./hooks/scripts/pre-compact.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "./hooks/scripts/stop.sh"
					}
				]
			}
		]
	}
}
