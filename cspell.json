{
	"$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/packages/cspell-types/cspell.schema.json",
	"allowCompoundWords": true,
	"caseSensitive": false,
	"dictionaries": [
		"companies",
		"css",
		"en_US",
		"filetypes",
		"fonts",
		"html",
		"misc",
		"node",
		"npm",
		"bun",
		"softwareTerms",
		"typescript"
	],
	"ignorePaths": [
		"plugins/typescript-architect/skills/code-quality-audit/references/anti-patterns.md"
	],
	"ignoreRandomStrings": true,
	"ignoreWords": [
		"mycompany",
		"mydb",
		"nothrow",
		"pyproject",
		"GHSA",
		"PKCE",
		"creational",
		"Liskov",
		"unrepresentable",
		"creds"
	],
	"words": ["meaganewaller", "bunx"]
}
